# Per-machine Codex / LLM Wiki configuration
.env
.env.*
!.env.example
.manifest.json

# Obsidian window and tab layout is machine-specific
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Local caches and trash
.obsidian/cache/
.trash/

# Operating-system and editor noise
.DS_Store
Thumbs.db
Desktop.ini
*.tmp
*.swp
__pycache__/
*.py[cod]

# Research packs keep sanitized evidence; local raw material stays untracked
_research/**/raw/
_research/**/downloads/
_research/**/cache/
_research/**/temp/
